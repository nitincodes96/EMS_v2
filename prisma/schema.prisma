generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  logoURL     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]
}

model Department {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique
  description    String?
  logoUrl        String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  workingDays      String @default("Mon,Tue,Wed,Thu,Fri")
  shiftStartTime   String @default("09:00")
  shiftEndTime     String @default("18:00")
  lateGraceMinutes Int    @default(5)

  // Feature flags (FR-2.9)
  geofenceEnabled  Boolean @default(false)
  bookingEnabled   Boolean @default(true)
  bookingStartTime String  @default("09:00")
  bookingEndTime   String  @default("17:00")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations   DepartmentLocation[]
  users       User[]
  holidays    Holiday[]
  leaves      Leave[]
  attendances Attendance[]
  bookings    Booking[]
}

model DepartmentLocation {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  latitude     Float
  longitude    Float
  radiusMeters Int        @default(100)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
}

model User {
  id           String      @id @default(uuid())
  email        String?     @unique
  empCode      String?     @unique
  username     String
  name         String?
  password     String?
  role         Role        @default(PROJECT_ASSISTANT)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  isActive    Boolean    @default(true)
  status      UserStatus @default(INVITED)
  joiningDate DateTime?

  // PA availability (punch-in) — FR-5.1/5.2
  isAvailable       Boolean   @default(false)
  availabilitySince DateTime?

  photoUrl     String?
  phoneNumber  String?

  isVerified Boolean   @default(false)
  otp        String?
  otpExpiry  DateTime?

  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?

  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaves          Leave[]
  attendances     Attendance[]
  facultyBookings Booking[]      @relation("FacultyBookings")
  paBookings      Booking[]      @relation("PABookings")
  approvedLeaves  Leave[]        @relation("LeaveApprover")
  notifications   Notification[]
  sessions        UserSession[]

  @@index([departmentId])
}

model Leave {
  id           String      @id @default(uuid())
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  leaveType    LeaveType   @default(CASUAL)
  reason       String?
  status       LeaveStatus @default(PENDING)

  // Approval routing — FR-6.2/6.3/6.4
  approverId     String?
  approver       User?     @relation("LeaveApprover", fields: [approverId], references: [id])
  decisionRemark String?
  decidedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId, status])
  @@index([userId])
  @@index([approverId])
}

model Attendance {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  date              DateTime  @db.Date
  checkInTime       DateTime
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkOutTime      DateTime?
  checkOutLatitude  Float?
  checkOutLongitude Float?

  // FR-3.3: flag when marked outside geofence
  flaggedOutsideGeofence Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([departmentId, date])
}

model Booking {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  facultyId String
  faculty   User   @relation("FacultyBookings", fields: [facultyId], references: [id], onDelete: Cascade)
  paId      String
  pa        User   @relation("PABookings", fields: [paId], references: [id], onDelete: Cascade)

  date      DateTime      @db.Date
  startTime DateTime
  endTime   DateTime
  workType  String?
  task      String        @db.Text
  status    BookingStatus @default(BOOKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId, date])
  @@index([facultyId])
  @@index([paId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERAL)
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  refId     String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device       String?
  userAgent    String?  @db.Text
  ipAddress    String?
  isSuspended  Boolean  @default(false)
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Holiday {
  id           String      @id @default(uuid())
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  date         DateTime    @db.Date
  type         HolidayType
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([departmentId, name, date])
  @@index([departmentId, date])
}

enum Role {
  ADMIN
  FACULTY
  PROJECT_ASSISTANT
}

enum UserStatus {
  INVITED
  ACCEPTED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  OTHER
}

enum BookingStatus {
  BOOKED
  COMPLETED
  ABSENT
  CANCELLED
}

enum NotificationType {
  GENERAL
  BOOKING
  LEAVE
  SESSION
}

enum HolidayType {
  NATIONAL
  RELIGIOUS
  CUSTOM
}
